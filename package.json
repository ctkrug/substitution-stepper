{
  "name": "substitution-stepper",
  "version": "0.1.0",
  "private": true,
  "description": "Paste a Scheme expression and watch it evaluate one substitution-model step at a time.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/substitution-stepper.git"
  },
  "homepage": "https://github.com/ctkrug/substitution-stepper",
  "keywords": [
    "scheme",
    "sicp",
    "interpreter",
    "substitution-model",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
